<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' - 知行智汇平台' : '知行智汇平台' %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#6C5CE7',
                        'primary-dark': '#5A4BD1',
                        secondary: '#00CEC9',
                        'secondary-dark': '#00B5B0',
                        accent: '#FD79A8',
                        'accent-warm': '#FDCB6E',
                        dark: '#2D3436',
                        neutral: '#F0F3F8',
                    },
                    fontFamily: {
                        sans: ['Noto Sans SC', 'Microsoft YaHei', 'sans-serif']
                    }
                }
            }
        }
    </script>
    <style>
        *, *::before, *::after { box-sizing: border-box; }

        body {
            background: linear-gradient(135deg, #a8edea 0%, #fed6e3 50%, #d299c2 100%);
            background-attachment: fixed;
            font-family: 'Noto Sans SC', 'Microsoft YaHei', sans-serif;
        }

        .glass {
            background: rgba(255, 255, 255, 0.25);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.4);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.15);
        }

        .glass-strong {
            background: rgba(255, 255, 255, 0.45);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.2);
        }

        .glass-dark {
            background: rgba(45, 52, 54, 0.7);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .card-hover {
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .card-hover:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 40px rgba(108, 92, 231, 0.18);
        }

        .nav-glass {
            background: rgba(108, 92, 231, 0.88);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            box-shadow: 0 4px 30px rgba(108, 92, 231, 0.2);
        }

        .nav-link {
            position: relative;
            transition: all 0.3s ease;
        }
        .nav-link::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 50%;
            width: 0;
            height: 3px;
            background: linear-gradient(90deg, #FD79A8, #FDCB6E);
            transition: all 0.3s ease;
            border-radius: 2px;
            transform: translateX(-50%);
        }
        .nav-link:hover::after {
            width: 100%;
        }

        .btn-primary {
            background: linear-gradient(135deg, #6C5CE7 0%, #A29BFE 100%);
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(108, 92, 231, 0.2);
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(108, 92, 231, 0.35);
        }

        .btn-secondary {
            background: linear-gradient(135deg, #00CEC9 0%, #81ECEC 100%);
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0, 206, 201, 0.2);
        }
        .btn-secondary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(0, 206, 201, 0.35);
        }

        .btn-accent {
            background: linear-gradient(135deg, #FD79A8 0%, #FDCB6E 100%);
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(253, 121, 168, 0.2);
        }
        .btn-accent:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(253, 121, 168, 0.35);
        }

        .gradient-text {
            background: linear-gradient(135deg, #6C5CE7, #FD79A8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .gradient-text-green {
            background: linear-gradient(135deg, #00CEC9, #55EFC4);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(5deg); }
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .animate-fadeInUp {
            animation: fadeInUp 0.6s ease-out forwards;
        }

        .animate-fadeInUp-delay-1 { animation-delay: 0.1s; opacity: 0; }
        .animate-fadeInUp-delay-2 { animation-delay: 0.2s; opacity: 0; }
        .animate-fadeInUp-delay-3 { animation-delay: 0.3s; opacity: 0; }

        .bubble {
            position: absolute;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(255,255,255,0.3), rgba(255,255,255,0.1));
            backdrop-filter: blur(4px);
            animation: float 6s ease-in-out infinite;
            pointer-events: none;
        }

        .page-header {
            background: linear-gradient(135deg, rgba(108,92,231,0.15), rgba(253,121,168,0.1));
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 20px;
        }

        .input-field {
            width: 100%;
            padding: 0.75rem 1rem;
            border-radius: 0.75rem;
            border: 2px solid rgba(108, 92, 231, 0.15);
            background: rgba(255, 255, 255, 0.8);
            transition: all 0.3s ease;
            outline: none;
        }
        .input-field:focus {
            border-color: #6C5CE7;
            box-shadow: 0 0 0 4px rgba(108, 92, 231, 0.1);
            background: white;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            border-radius: 16px;
            transition: all 0.3s ease;
        }
        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 30px rgba(108, 92, 231, 0.12);
        }

        footer {
            background: rgba(45, 52, 54, 0.8);
            backdrop-filter: blur(12px);
        }

        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: rgba(255,255,255,0.1); }
        ::-webkit-scrollbar-thumb { background: rgba(108,92,231,0.3); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(108,92,231,0.5); }

        @media (max-width: 768px) {
            .mobile-nav {
                background: rgba(108, 92, 231, 0.95);
                backdrop-filter: blur(12px);
            }
        }
    </style>
</head>
<body class="min-h-screen flex flex-col">
    <nav class="nav-glass text-white shadow-lg sticky top-0 z-50">
        <div class="container mx-auto px-4">
            <div class="flex items-center justify-between h-16">
                <a href="/" class="text-xl font-bold flex items-center gap-2 hover:opacity-90 transition">
                    <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3zm6.82 6L12 12.72 5.18 9 12 5.28 18.82 9zM17 15.99l-5 2.73-5-2.73v-3.72L12 15l5-2.73v3.72z"/>
                    </svg>
                    <span class="gradient-text font-black text-xl">知行智汇</span>
                </a>

                <div class="hidden md:flex items-center space-x-6">
                    <a href="/resources" class="nav-link py-2 px-1 text-sm font-medium">资源浏览</a>
                    <a href="/tasks" class="nav-link py-2 px-1 text-sm font-medium">任务卡</a>
                    <a href="/quiz" class="nav-link py-2 px-1 text-sm font-medium">大单元闯关</a>
                    <a href="/questions" class="nav-link py-2 px-1 text-sm font-medium">提问信箱</a>
                </div>

                <div class="flex items-center gap-3">
                    <% if (isAuthenticated) { %>
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center text-sm font-bold">
                                <%= currentUser.realName.charAt(0) %>
                            </div>
                            <span class="text-sm opacity-90 hidden sm:inline">
                                <%= currentUser.role === 'teacher' ? '教师' : '学生' %>
                            </span>
                            <a href="/<%= currentUser.role %>" class="btn-accent px-4 py-1.5 rounded-lg text-sm font-medium text-white">
                                个人中心
                            </a>
                            <a href="/logout" class="opacity-70 hover:opacity-100 text-sm transition">退出</a>
                        </div>
                    <% } else { %>
                        <a href="/login" class="opacity-80 hover:opacity-100 transition text-sm font-medium">登录</a>
                        <a href="/register" class="btn-accent px-4 py-1.5 rounded-lg text-sm font-medium text-white">
                            注册
                        </a>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="md:hidden mobile-nav border-t border-white/20">
            <div class="flex justify-around py-2 text-sm">
                <a href="/resources" class="py-1 flex flex-col items-center gap-0.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                    资源
                </a>
                <a href="/tasks" class="py-1 flex flex-col items-center gap-0.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                    任务
                </a>
                <a href="/quiz" class="py-1 flex flex-col items-center gap-0.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    闯关
                </a>
                <a href="/questions" class="py-1 flex flex-col items-center gap-0.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                    信箱
                </a>
            </div>
        </div>
    </nav>

    <main class="flex-grow">
        <%- body %>
    </main>

    <%- include('partials/footer-content') %>
</body>
</html>