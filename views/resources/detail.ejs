<%- include('../partials/header') %>

<style>
#markdownContent h1 { font-size: 1.75rem; font-weight: 700; margin: 1rem 0 0.75rem; color: #1f2937; }
#markdownContent h2 { font-size: 1.5rem; font-weight: 700; margin: 1rem 0 0.75rem; color: #1f2937; }
#markdownContent h3 { font-size: 1.25rem; font-weight: 600; margin: 0.75rem 0 0.5rem; color: #1f2937; }
#markdownContent p { margin: 0.5rem 0; line-height: 1.75; color: #374151; }
#markdownContent ul, #markdownContent ol { margin: 0.5rem 0; padding-left: 1.5rem; }
#markdownContent li { margin: 0.25rem 0; color: #374151; }
#markdownContent code { background: #f3f4f6; padding: 0.2rem 0.4rem; border-radius: 0.25rem; font-size: 0.875rem; color: #e11d48; }
#markdownContent pre { background: #1f2937; color: #e5e7eb; padding: 1rem; border-radius: 0.75rem; overflow-x: auto; margin: 0.75rem 0; }
#markdownContent pre code { background: transparent; color: inherit; padding: 0; }
#markdownContent blockquote { border-left: 4px solid #6C5CE7; padding-left: 1rem; margin: 0.75rem 0; color: #6b7280; font-style: italic; }
#markdownContent img { max-width: 100%; border-radius: 0.5rem; margin: 0.5rem 0; }
#markdownContent table { width: 100%; border-collapse: collapse; margin: 0.75rem 0; }
#markdownContent th, #markdownContent td { border: 1px solid #e5e7eb; padding: 0.5rem 0.75rem; text-align: left; }
#markdownContent th { background: #f9fafb; font-weight: 600; }
#markdownContent a { color: #6C5CE7; text-decoration: underline; }
#markdownContent a:hover { color: #5A4BD1; }
#markdownContent hr { border: none; border-top: 1px solid #e5e7eb; margin: 1rem 0; }
</style>

<div class="container mx-auto px-4 py-8">
    <div class="max-w-3xl mx-auto">
        <a href="/resources?area=<%= resource.unit_area %>" class="inline-flex items-center text-gray-500 hover:text-primary mb-6">
            <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            返回列表
        </a>

        <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
            <% if (resource.images && resource.images.length > 0) { %>
            <div class="relative">
                <div class="h-80 bg-gray-200">
                    <img src="<%= resource.images[0] %>" class="w-full h-full object-cover">
                </div>
                <% if (resource.images.length > 1) { %>
                <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2">
                    <% resource.images.forEach(function(img, i) { %>
                        <button onclick="showImage(<%= i %>)" class="w-3 h-3 rounded-full <%= i === 0 ? 'bg-white' : 'bg-white/50' %>"></button>
                    <% }); %>
                </div>
                <% } %>
            </div>
            <% } %>

            <div class="p-8">
                <div class="flex items-start justify-between mb-6">
                    <div>
                        <div class="flex items-center gap-2 mb-2">
                            <span class="px-3 py-1 rounded-full text-sm <%= resource.is_public === 2 ? 'bg-purple-100 text-purple-700' : 'bg-blue-100 text-blue-700' %>">
                                <%= resource.is_public === 2 ? '教师发布' : '学生分享' %>
                            </span>
                            <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-700 text-sm"><%= resource.unit_area %></span>
                        </div>
                        <h1 class="text-2xl font-bold text-gray-800"><%= resource.title %></h1>
                    </div>
                    <% if (typeof user !== 'undefined' && user && (resource.author_id === user.id || user.role === 'superadmin' || user.role === 'admin')) { %>
                    <a href="/resources/<%= resource.id %>/edit" class="px-4 py-2 text-sm font-medium text-primary border border-primary/30 rounded-lg hover:bg-primary/5 transition flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        编辑
                    </a>
                    <% } %>
                </div>

                <div class="flex items-center gap-3 mb-6 pb-6 border-b border-gray-200">
                    <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
                        <span class="font-medium text-primary"><%= resource.author_name.charAt(0) %></span>
                    </div>
                    <div>
                        <p class="font-medium text-gray-800"><%= resource.author_name %></p>
                        <p class="text-sm text-gray-500"><%= resource.created_at %></p>
                    </div>
                </div>

                <div class="mb-8">
                    <h2 class="text-lg font-bold text-gray-800 mb-3">内容描述</h2>
                    <div id="markdownContent" class="prose prose-gray max-w-none">
                        <%= resource.content || '暂无描述' %>
                    </div>
                </div>

                <% if (resource.unit_level || resource.point_name) { %>
                <div class="bg-gray-50 rounded-xl p-6">
                    <h3 class="font-bold text-gray-800 mb-3">相关信息</h3>
                    <div class="grid grid-cols-2 gap-4 text-sm">
                        <% if (resource.unit_level) { %>
                        <div>
                            <p class="text-gray-500">大单元层次</p>
                            <p class="font-medium text-gray-800"><%= resource.unit_level %></p>
                        </div>
                        <% } %>
                        <% if (resource.point_name) { %>
                        <div>
                            <p class="text-gray-500">相关点位</p>
                            <p class="font-medium text-gray-800"><%= resource.point_name %></p>
                        </div>
                        <% } %>
                    </div>
                </div>
                <% } %>

                <% if (resource.images && resource.images.length > 1) { %>
                <div class="mt-8">
                    <h2 class="text-lg font-bold text-gray-800 mb-4">图片集</h2>
                    <div class="grid grid-cols-3 gap-3">
                        <% resource.images.forEach(function(img, i) { %>
                        <div class="aspect-square rounded-lg overflow-hidden bg-gray-200 cursor-pointer hover:opacity-80 transition" onclick="showImage(<%= i %>)">
                            <img src="<%= img %>" class="w-full h-full object-cover">
                        </div>
                        <% }); %>
                    </div>
                </div>
                <% } %>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-xl mt-6 p-8">
            <h2 class="text-lg font-bold text-gray-800 mb-6 flex items-center gap-2">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-1.114L3 21l1.114-4.255A9.863 9.863 0 013 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                评论 <span class="text-sm font-normal text-gray-400">(<%= comments ? comments.length : 0 %>)</span>
            </h2>

            <% if (user) { %>
            <form action="/resources/<%= resource.id %>/comments" method="POST" class="mb-8" id="commentForm">
                <div class="flex gap-4">
                    <div class="w-10 h-10 bg-primary/10 rounded-full flex-shrink-0 flex items-center justify-center">
                        <span class="font-medium text-primary"><%= (user.realName || user.username).charAt(0) %></span>
                    </div>
                    <div class="flex-1">
                        <div id="replyToBox" class="hidden mb-2 p-3 bg-blue-50 border-l-4 border-blue-400 rounded-r-lg text-sm">
                            <div class="flex items-center justify-between">
                                <span class="text-blue-600 font-medium">回复 <span id="replyToAuthor"></span></span>
                                <button type="button" onclick="cancelReply()" class="text-blue-400 hover:text-blue-600">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                                </button>
                            </div>
                            <p id="replyToContent" class="text-blue-500 mt-1 truncate"></p>
                            <input type="hidden" name="reply_to_id" id="replyToId">
                            <input type="hidden" name="reply_to_content" id="replyToContentInput">
                        </div>
                        <textarea name="content" id="commentContent" rows="3" required placeholder="写下你的评论..." class="w-full p-3 border border-gray-200 rounded-xl focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition resize-none text-gray-700"></textarea>
                        <div class="flex justify-end mt-2">
                            <button type="submit" class="btn-primary text-white px-6 py-2 rounded-xl text-sm font-medium">发表评论</button>
                        </div>
                    </div>
                </div>
            </form>
            <% } else { %>
            <div class="mb-8 p-4 bg-gray-50 rounded-xl text-center text-gray-500">
                <a href="/login" class="text-primary hover:underline font-medium">登录</a> 后即可发表评论
            </div>
            <% } %>

            <% if (comments && comments.length > 0) { %>
            <div class="space-y-6">
                <% comments.forEach(function(c) { %>
                <div class="flex gap-4 pb-6 border-b border-gray-100 last:border-0 last:pb-0">
                    <div class="w-10 h-10 <%= c.author_role === 'teacher' ? 'bg-green-100 text-green-600' : 'bg-primary/10 text-primary' %> rounded-full flex-shrink-0 flex items-center justify-center">
                        <span class="font-medium"><%= (c.author_name || '?').charAt(0) %></span>
                    </div>
                    <div class="flex-1">
                        <div class="flex items-center gap-2 mb-1">
                            <span class="font-medium text-gray-800"><%= c.author_name || '匿名' %></span>
                            <% if (c.author_role === 'teacher') { %>
                            <span class="px-2 py-0.5 rounded text-xs bg-green-100 text-green-600">教师</span>
                            <% } else if (c.author_role === 'superadmin' || c.author_role === 'admin') { %>
                            <span class="px-2 py-0.5 rounded text-xs bg-purple-100 text-purple-600">管理员</span>
                            <% } %>
                            <span class="text-xs text-gray-400"><%= c.created_at %></span>
                        </div>
                        <% if (c.reply_to_content) { %>
                        <div class="mb-2 p-2 bg-gray-50 border-l-3 border-gray-300 rounded-r text-sm text-gray-500">
                            <svg class="w-3 h-3 inline mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/></svg>
                            <%= c.reply_to_content %>
                        </div>
                        <% } %>
                        <p class="text-gray-700 leading-relaxed whitespace-pre-wrap"><%= c.content %></p>
                        <div class="flex items-center gap-3 mt-2">
                            <% if (user) { %>
                            <button onclick="replyTo(<%= c.id %>, '<%= (c.author_name || "匿名").replace(/'/g, "\\'") %>', `<%= c.content.replace(/`/g, "\\`").replace(/\\/g, "\\\\").substring(0, 100) %><%= c.content.length > 100 ? '...' : '' %>`)"
                                class="text-xs text-gray-400 hover:text-primary transition flex items-center gap-1">
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/></svg>
                                回复
                            </button>
                            <% } %>
                            <% if (user && (c.author_id === user.id || user.role === 'superadmin')) { %>
                            <form action="/resources/<%= resource.id %>/comments/<%= c.id %>/delete" method="POST" class="inline" onsubmit="return confirm('确定删除这条评论吗？')">
                                <button type="submit" class="text-xs text-gray-400 hover:text-red-500 transition">删除</button>
                            </form>
                            <% } %>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
            <% } else { %>
            <p class="text-gray-400 text-center py-8">暂无评论，快来发表第一条吧</p>
            <% } %>
        </div>
    </div>
</div>

<div id="imageModal" class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center" onclick="closeModal()">
    <button class="absolute top-4 right-4 text-white hover:text-gray-300">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
    </button>
    <button onclick="prevImage()" class="absolute left-4 text-white hover:text-gray-300">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
    </button>
    <button onclick="nextImage()" class="absolute right-4 text-white hover:text-gray-300">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
    </button>
    <img id="modalImage" src="" class="max-w-full max-h-full object-contain">
</div>

<script>
let currentImageIndex = 0;
const images = <%- JSON.stringify(resource.images || []) %>;

function showImage(index) {
    currentImageIndex = index;
    document.getElementById('modalImage').src = images[index];
    document.getElementById('imageModal').classList.remove('hidden');
    document.getElementById('imageModal').classList.add('flex');
}

function closeModal() {
    document.getElementById('imageModal').classList.add('hidden');
    document.getElementById('imageModal').classList.remove('flex');
}

function prevImage() {
    currentImageIndex = (currentImageIndex - 1 + images.length) % images.length;
    document.getElementById('modalImage').src = images[currentImageIndex];
}

function nextImage() {
    currentImageIndex = (currentImageIndex + 1) % images.length;
    document.getElementById('modalImage').src = images[currentImageIndex];
}

document.addEventListener('keydown', function(e) {
    if (document.getElementById('imageModal').classList.contains('flex')) {
        if (e.key === 'Escape') closeModal();
        if (e.key === 'ArrowLeft') prevImage();
        if (e.key === 'ArrowRight') nextImage();
    }
});

// 引用回复功能
function replyTo(commentId, authorName, content) {
    document.getElementById('replyToBox').classList.remove('hidden');
    document.getElementById('replyToAuthor').textContent = authorName;
    document.getElementById('replyToContent').textContent = content;
    document.getElementById('replyToId').value = commentId;
    document.getElementById('replyToContentInput').value = content;
    document.getElementById('commentContent').focus();
    document.getElementById('commentContent').placeholder = '回复 ' + authorName + '...';
    // 滚动到评论框
    document.getElementById('commentForm').scrollIntoView({ behavior: 'smooth', block: 'center' });
}

function cancelReply() {
    document.getElementById('replyToBox').classList.add('hidden');
    document.getElementById('replyToId').value = '';
    document.getElementById('replyToContentInput').value = '';
    document.getElementById('commentContent').placeholder = '写下你的评论...';
}
</script>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const mdElement = document.getElementById('markdownContent');
    if (mdElement) {
        const rawContent = mdElement.textContent.trim();
        if (rawContent && rawContent !== '暂无描述') {
            try {
                mdElement.innerHTML = marked.parse(rawContent);
                mdElement.classList.add('prose', 'prose-gray', 'max-w-none');
            } catch (e) {
                mdElement.classList.add('whitespace-pre-wrap');
            }
        }
    }
});
</script>

<%- include('../partials/footer') %>
