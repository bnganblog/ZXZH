<%- include('_header', { activeMenu: 'questions', title: '问答管理' }) %>
<div class="animate-fadeInUp">
    <div class="admin-card p-6 mb-6">
        <form method="GET" action="/admin/questions" class="flex flex-wrap items-center gap-4">
            <div class="flex items-center gap-2">
                <label class="text-sm text-gray-600 font-medium">状态</label>
                <select name="status" class="input-field !w-36 !py-2 !text-sm">
                    <option value="" <%= typeof filterStatus !== 'undefined' && !filterStatus ? 'selected' : '' %>>全部</option>
                    <option value="answered" <%= typeof filterStatus !== 'undefined' && filterStatus === 'answered' ? 'selected' : '' %>>已回答</option>
                    <option value="unanswered" <%= typeof filterStatus !== 'undefined' && filterStatus === 'unanswered' ? 'selected' : '' %>>未回答</option>
                </select>
            </div>
            <div class="flex-1 min-w-[200px]">
                <input type="text" name="search" value="<%= typeof search !== 'undefined' ? search : '' %>"
                    class="input-field !py-2 !text-sm" placeholder="搜索问题内容或作者...">
            </div>
            <button type="submit" class="btn-primary text-white px-5 py-2 rounded-lg text-sm font-medium">
                搜索
            </button>
            <a href="/admin/questions" class="text-gray-500 hover:text-gray-700 text-sm transition">重置</a>
        </form>
    </div>

    <div class="space-y-4 mb-6">
        <% if (typeof questions !== 'undefined' && questions && questions.length > 0) { %>
            <% questions.forEach(function(q) { %>
            <div class="admin-card p-6">
                <div class="flex items-start justify-between gap-4 mb-3">
                    <div class="flex-1">
                        <div class="flex items-center gap-3 mb-2">
                            <% if (q.answered) { %>
                                <span class="badge badge-green">已回答</span>
                            <% } else { %>
                                <span class="badge badge-orange">未回答</span>
                            <% } %>
                            <span class="text-xs text-gray-400"><%= q.createdAt %></span>
                        </div>
                        <p class="text-sm text-dark leading-relaxed"><%= q.content %></p>
                    </div>
                    <div class="flex items-center gap-2 flex-shrink-0">
                        <button onclick="deleteQuestion(<%= q.id %>)"
                            class="text-xs text-red-500 hover:text-red-700 hover:bg-red-50 px-3 py-1.5 rounded-lg transition font-medium">
                            删除问题
                        </button>
                    </div>
                </div>
                <div class="flex items-center gap-2 text-xs text-gray-500 mb-3">
                    <div class="w-6 h-6 rounded-md bg-gradient-to-br from-primary to-accent flex items-center justify-center text-white text-[10px] font-bold">
                        <%= q.author ? q.author.charAt(0) : 'U' %>
                    </div>
                    <span><%= q.author || '匿名用户' %></span>
                </div>
                <% if (q.answered && q.answer) { %>
                <div class="ml-4 pl-4 border-l-2 border-primary/30 bg-primary/3 rounded-r-lg py-3 pr-4">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-xs font-medium text-primary">回答内容</span>
                        <button onclick="deleteAnswer(<%= q.id %>)"
                            class="text-xs text-red-500 hover:text-red-700 hover:bg-red-50 px-2 py-1 rounded transition font-medium">
                            删除回答
                        </button>
                    </div>
                    <p class="text-sm text-gray-600 leading-relaxed"><%= q.answer.content %></p>
                    <div class="flex items-center gap-2 text-xs text-gray-400 mt-2">
                        <span><%= q.answer.author || '教师' %></span>
                        <span>·</span>
                        <span><%= q.answer.createdAt %></span>
                    </div>
                </div>
                <% } %>
            </div>
            <% }); %>
        <% } else { %>
            <div class="admin-card p-12 text-center text-gray-400">
                <svg class="w-12 h-12 mx-auto mb-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                <p>暂无提问数据</p>
            </div>
        <% } %>
    </div>

    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
    <div class="flex items-center justify-between">
        <p class="text-sm text-gray-500">
            共 <span class="font-medium text-gray-700"><%= typeof total !== 'undefined' ? total : 0 %></span> 条记录
        </p>
        <div class="pagination">
            <% if (typeof currentPage !== 'undefined' && currentPage > 1) { %>
                <a href="?page=<%= currentPage - 1 %>">上一页</a>
            <% } else { %>
                <span class="disabled">上一页</span>
            <% } %>
            <% for (let i = 1; i <= totalPages; i++) { %>
                <% if (i === currentPage) { %>
                    <span class="active"><%= i %></span>
                <% } else { %>
                    <a href="?page=<%= i %>"><%= i %></a>
                <% } %>
            <% } %>
            <% if (typeof currentPage !== 'undefined' && currentPage < totalPages) { %>
                <a href="?page=<%= currentPage + 1 %>">下一页</a>
            <% } else { %>
                <span class="disabled">下一页</span>
            <% } %>
        </div>
    </div>
    <% } %>
</div>

<script>
function deleteQuestion(questionId) {
    if (!confirm('确定要删除该问题吗？相关回答也将被删除，此操作不可撤销！')) return;
    fetch('/admin/api/questions/' + questionId, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' }
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert(data.message || '删除失败');
        }
    })
    .catch(() => alert('请求失败，请重试'));
}

function deleteAnswer(questionId) {
    if (!confirm('确定要删除该回答吗？')) return;
    fetch('/admin/api/questions/' + questionId + '/answer', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' }
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert(data.message || '删除失败');
        }
    })
    .catch(() => alert('请求失败，请重试'));
}
</script>
<%- include('_footer') %>