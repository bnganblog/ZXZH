<%- include('_header', { activeMenu: 'ai-config', title: 'AI配置管理' }) %>
<div class="animate-fadeInUp max-w-3xl">
    <div class="admin-card p-6 mb-6">
        <h2 class="text-lg font-bold text-gray-800 mb-1">AI服务配置</h2>
        <p class="text-sm text-gray-500 mb-6">配置兼容OpenAI格式的AI接口，用于信箱AI问答功能</p>

        <% if (typeof success !== 'undefined' && success) { %>
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl mb-6 flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            配置已保存
        </div>
        <% } %>

        <% if (typeof error !== 'undefined' && error) { %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl mb-6 flex items-center gap-2">
            <svg class="w-5 h-5 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
            <%= error %>
        </div>
        <% } %>

        <form action="/admin/ai-config" method="POST" class="space-y-5">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">API地址 <span class="text-red-500">*</span></label>
                <input type="url" name="api_url" value="<%= config.api_url %>" required
                    class="input-field"
                    placeholder="https://api.example.com/v1/chat/completions">
                <p class="text-xs text-gray-400 mt-1">OpenAI兼容接口地址，如 https://api.openai.com/v1/chat/completions</p>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">API Key <span class="text-red-500">*</span></label>
                <div class="relative">
                    <input type="password" name="api_key" id="apiKeyInput" value="<%= config.api_key %>" required
                        class="input-field pr-10"
                        placeholder="sk-...">
                    <button type="button" onclick="toggleApiKey()" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                        <svg id="eyeIcon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                    </button>
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">模型名称 <span class="text-red-500">*</span></label>
                <input type="text" name="model_name" value="<%= config.model_name %>" required
                    class="input-field"
                    placeholder="gpt-3.5-turbo">
                <p class="text-xs text-gray-400 mt-1">如 gpt-3.5-turbo、gpt-4、deepseek-chat 等</p>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">系统提示词</label>
                <textarea name="system_prompt" rows="4"
                    class="input-field resize-none"
                    placeholder="定义AI的角色和行为..."><%= config.system_prompt %></textarea>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Temperature</label>
                    <input type="number" name="temperature" value="<%= config.temperature %>" min="0" max="2" step="0.1"
                        class="input-field">
                    <p class="text-xs text-gray-400 mt-1">0=精确，1=创造性，推荐0.7</p>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Max Tokens</label>
                    <input type="number" name="max_tokens" value="<%= config.max_tokens %>" min="1" max="8192"
                        class="input-field">
                    <p class="text-xs text-gray-400 mt-1">单次回复最大长度</p>
                </div>
            </div>

            <div class="flex items-center gap-3 pt-2">
                <button type="submit" class="btn-primary text-white px-6 py-2.5 rounded-xl text-sm font-medium">
                    保存配置
                </button>
                <button type="button" onclick="testConnection()"
                    class="px-6 py-2.5 rounded-xl text-sm font-medium border border-gray-200 text-gray-700 hover:bg-gray-50 transition">
                    测试连接
                </button>
                <span id="testResult" class="text-sm"></span>
            </div>
        </form>
    </div>
</div>

<script>
function toggleApiKey() {
    const input = document.getElementById('apiKeyInput');
    input.type = input.type === 'password' ? 'text' : 'password';
}

function testConnection() {
    const btn = event.target;
    const result = document.getElementById('testResult');
    btn.disabled = true;
    btn.textContent = '测试中...';
    result.textContent = '';

    fetch('/admin/api/ai/test', { method: 'POST' })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                result.innerHTML = '<span class="text-green-600">连接成功，模型响应正常</span>';
            } else {
                result.innerHTML = '<span class="text-red-600">' + (data.message || '连接失败') + '</span>';
            }
        })
        .catch(() => {
            result.innerHTML = '<span class="text-red-600">请求失败，请检查配置</span>';
        })
        .finally(() => {
            btn.disabled = false;
            btn.textContent = '测试连接';
        });
}
</script>
<%- include('_footer') %>
