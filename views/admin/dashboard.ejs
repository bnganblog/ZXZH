<%- include('_header', { activeMenu: 'dashboard', title: '仪表板' }) %>
<div class="animate-fadeInUp">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="stat-card p-6">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary to-primary-light flex items-center justify-center shadow-lg">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 9a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <span class="text-xs font-medium text-green-500 bg-green-50 px-2 py-1 rounded-full">+<%= typeof stats !== 'undefined' && stats.todayNewUsers ? stats.todayNewUsers : 0 %></span>
            </div>
            <p class="text-2xl font-bold text-dark"><%= typeof stats !== 'undefined' && stats.totalUsers ? stats.totalUsers : 0 %></p>
            <p class="text-sm text-gray-500 mt-1">总用户数</p>
        </div>
        <div class="stat-card p-6">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-secondary to-emerald-400 flex items-center justify-center shadow-lg">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                </div>
            </div>
            <p class="text-2xl font-bold text-dark"><%= typeof stats !== 'undefined' && stats.totalResources ? stats.totalResources : 0 %></p>
            <p class="text-sm text-gray-500 mt-1">总资源数</p>
        </div>
        <div class="stat-card p-6">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-accent to-accent-warm flex items-center justify-center shadow-lg">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                </div>
            </div>
            <p class="text-2xl font-bold text-dark"><%= typeof stats !== 'undefined' && stats.totalQuestions ? stats.totalQuestions : 0 %></p>
            <p class="text-sm text-gray-500 mt-1">总提问数</p>
        </div>
        <div class="stat-card p-6">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center shadow-lg">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                </div>
            </div>
            <p class="text-2xl font-bold text-dark"><%= typeof stats !== 'undefined' && stats.todayNewUsers ? stats.todayNewUsers : 0 %></p>
            <p class="text-sm text-gray-500 mt-1">今日新增用户</p>
        </div>
    </div>

    <div class="admin-card p-6 mb-6">
        <h3 class="text-lg font-bold text-dark mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            最近活动
        </h3>
        <div class="space-y-4">
            <% if (typeof activities !== 'undefined' && activities && activities.length > 0) { %>
                <% activities.forEach(function(activity) { %>
                <div class="flex items-start gap-4 p-3 rounded-xl hover:bg-gray-50 transition">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0
                        <%= activity.type === 'user' ? 'bg-gradient-to-br from-primary to-primary-light' : activity.type === 'resource' ? 'bg-gradient-to-br from-secondary to-emerald-400' : 'bg-gradient-to-br from-accent to-accent-warm' %>">
                        <% if (activity.type === 'user') { %>
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        <% } else if (activity.type === 'resource') { %>
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        <% } else { %>
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                        <% } %>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium text-dark"><%= activity.title %></p>
                        <p class="text-xs text-gray-500 mt-0.5"><%= activity.description %></p>
                    </div>
                    <span class="text-xs text-gray-400 flex-shrink-0"><%= activity.time %></span>
                </div>
                <% }); %>
            <% } else { %>
                <div class="text-center py-8 text-gray-400">
                    <svg class="w-12 h-12 mx-auto mb-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
                    <p class="text-sm">暂无活动记录</p>
                </div>
            <% } %>
        </div>
    </div>
</div>
<%- include('_footer') %>