<%- include('_header', { activeMenu: 'stats', title: '数据统计' }) %>
<div class="animate-fadeInUp">
    <div class="admin-card p-6 mb-6">
        <h3 class="text-lg font-bold text-dark mb-5 flex items-center gap-2">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-primary to-primary-light flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 9a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            用户统计
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
            <div class="stat-card p-4 text-center">
                <p class="text-3xl font-bold bg-gradient-to-r from-primary to-primary-light bg-clip-text text-transparent"><%= typeof stats !== 'undefined' && stats.userTotal ? stats.userTotal : 0 %></p>
                <p class="text-xs text-gray-500 mt-1">总用户</p>
            </div>
            <div class="stat-card p-4 text-center">
                <p class="text-3xl font-bold bg-gradient-to-r from-blue-500 to-cyan-400 bg-clip-text text-transparent"><%= typeof stats !== 'undefined' && stats.studentTotal ? stats.studentTotal : 0 %></p>
                <p class="text-xs text-gray-500 mt-1">学生</p>
            </div>
            <div class="stat-card p-4 text-center">
                <p class="text-3xl font-bold bg-gradient-to-r from-green-500 to-emerald-400 bg-clip-text text-transparent"><%= typeof stats !== 'undefined' && stats.teacherTotal ? stats.teacherTotal : 0 %></p>
                <p class="text-xs text-gray-500 mt-1">教师</p>
            </div>
            <div class="stat-card p-4 text-center">
                <p class="text-3xl font-bold bg-gradient-to-r from-accent to-accent-warm bg-clip-text text-transparent"><%= typeof stats !== 'undefined' && stats.newToday ? stats.newToday : 0 %></p>
                <p class="text-xs text-gray-500 mt-1">今日新增</p>
            </div>
            <div class="stat-card p-4 text-center">
                <p class="text-3xl font-bold bg-gradient-to-r from-secondary to-emerald-400 bg-clip-text text-transparent"><%= typeof stats !== 'undefined' && stats.newWeek ? stats.newWeek : 0 %></p>
                <p class="text-xs text-gray-500 mt-1">近7天新增</p>
            </div>
        </div>
        <% if (typeof stats !== 'undefined' && stats.activeToday) { %>
        <div class="mt-4 pt-4 border-t border-gray-100 flex items-center gap-2 text-sm text-gray-600">
            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            今日活跃用户：<span class="font-bold text-primary"><%= stats.activeToday %></span>
        </div>
        <% } %>
    </div>

    <div class="admin-card p-6 mb-6">
        <h3 class="text-lg font-bold text-dark mb-5 flex items-center gap-2">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-secondary to-emerald-400 flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
            </div>
            资源统计
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
            <div class="stat-card p-4 text-center">
                <p class="text-3xl font-bold bg-gradient-to-r from-secondary to-emerald-400 bg-clip-text text-transparent"><%= typeof stats !== 'undefined' && stats.resourceTotal ? stats.resourceTotal : 0 %></p>
                <p class="text-xs text-gray-500 mt-1">总资源</p>
            </div>
            <div class="stat-card p-4 text-center">
                <p class="text-3xl font-bold bg-gradient-to-r from-blue-500 to-cyan-400 bg-clip-text text-transparent"><%= typeof stats !== 'undefined' && stats.resourcePublic ? stats.resourcePublic : 0 %></p>
                <p class="text-xs text-gray-500 mt-1">公开</p>
            </div>
            <div class="stat-card p-4 text-center">
                <p class="text-3xl font-bold bg-gradient-to-r from-primary to-primary-light bg-clip-text text-transparent"><%= typeof stats !== 'undefined' && stats.resourceTeacher ? stats.resourceTeacher : 0 %></p>
                <p class="text-xs text-gray-500 mt-1">教师</p>
            </div>
            <div class="stat-card p-4 text-center">
                <p class="text-3xl font-bold bg-gradient-to-r from-gray-500 to-gray-400 bg-clip-text text-transparent"><%= typeof stats !== 'undefined' && stats.resourcePrivate ? stats.resourcePrivate : 0 %></p>
                <p class="text-xs text-gray-500 mt-1">私有</p>
            </div>
            <div class="stat-card p-4 text-center">
                <p class="text-3xl font-bold bg-gradient-to-r from-accent to-accent-warm bg-clip-text text-transparent"><%= typeof stats !== 'undefined' && stats.resourceNewToday ? stats.resourceNewToday : 0 %></p>
                <p class="text-xs text-gray-500 mt-1">今日新增</p>
            </div>
        </div>
    </div>

    <div class="admin-card p-6 mb-6">
        <h3 class="text-lg font-bold text-dark mb-5 flex items-center gap-2">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent to-accent-warm flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
            </div>
            问答统计
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="stat-card p-4 text-center">
                <p class="text-3xl font-bold bg-gradient-to-r from-accent to-accent-warm bg-clip-text text-transparent"><%= typeof stats !== 'undefined' && stats.questionTotal ? stats.questionTotal : 0 %></p>
                <p class="text-xs text-gray-500 mt-1">总提问</p>
            </div>
            <div class="stat-card p-4 text-center">
                <p class="text-3xl font-bold bg-gradient-to-r from-green-500 to-emerald-400 bg-clip-text text-transparent"><%= typeof stats !== 'undefined' && stats.questionAnswered ? stats.questionAnswered : 0 %></p>
                <p class="text-xs text-gray-500 mt-1">已回答</p>
            </div>
            <div class="stat-card p-4 text-center">
                <p class="text-3xl font-bold bg-gradient-to-r from-orange-500 to-yellow-400 bg-clip-text text-transparent"><%= typeof stats !== 'undefined' && stats.questionUnanswered ? stats.questionUnanswered : 0 %></p>
                <p class="text-xs text-gray-500 mt-1">未回答</p>
            </div>
            <div class="stat-card p-4 text-center">
                <p class="text-3xl font-bold bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent"><%= typeof stats !== 'undefined' && stats.answerRate ? stats.answerRate : 0 %>%</p>
                <p class="text-xs text-gray-500 mt-1">回答率</p>
            </div>
        </div>
    </div>

    <div class="admin-card p-6">
        <h3 class="text-lg font-bold text-dark mb-5 flex items-center gap-2">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            闯关统计
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-6">
            <div class="stat-card p-4 text-center">
                <p class="text-3xl font-bold bg-gradient-to-r from-blue-500 to-cyan-400 bg-clip-text text-transparent"><%= typeof stats !== 'undefined' && stats.quizTotalAttempts ? stats.quizTotalAttempts : 0 %></p>
                <p class="text-xs text-gray-500 mt-1">总尝试次数</p>
            </div>
            <div class="stat-card p-4 text-center">
                <p class="text-3xl font-bold bg-gradient-to-r from-green-500 to-emerald-400 bg-clip-text text-transparent"><%= typeof stats !== 'undefined' && stats.quizCorrect ? stats.quizCorrect : 0 %></p>
                <p class="text-xs text-gray-500 mt-1">正确次数</p>
            </div>
            <div class="stat-card p-4 text-center">
                <p class="text-3xl font-bold bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent"><%= typeof stats !== 'undefined' && stats.quizAccuracy ? stats.quizAccuracy : 0 %>%</p>
                <p class="text-xs text-gray-500 mt-1">正确率</p>
            </div>
        </div>
        <% if (typeof stats !== 'undefined' && stats.quizByLevel && stats.quizByLevel.length > 0) { %>
        <div class="overflow-hidden rounded-xl border border-gray-100">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>单元级别</th>
                        <th>尝试次数</th>
                        <th>正确次数</th>
                        <th>正确率</th>
                    </tr>
                </thead>
                <tbody>
                    <% stats.quizByLevel.forEach(function(level) { %>
                    <tr>
                        <td class="font-medium"><%= level.name %></td>
                        <td><%= level.attempts %></td>
                        <td><%= level.correct %></td>
                        <td>
                            <div class="flex items-center gap-2">
                                <div class="flex-1 h-2 bg-gray-100 rounded-full overflow-hidden">
                                    <div class="h-full rounded-full bg-gradient-to-r from-primary to-accent" style="width: <%= level.rate %>%"></div>
                                </div>
                                <span class="text-xs font-medium text-primary"><%= level.rate %>%</span>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
        <% } %>
    </div>
</div>
<%- include('_footer') %>