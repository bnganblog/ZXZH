<%- include('partials/header') %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/simplemde/latest/simplemde.min.css">

<div class="container mx-auto px-4 py-8">
    <div class="max-w-2xl mx-auto">
        <div class="glass-strong rounded-2xl p-8 animate-fadeInUp">
            <div class="flex items-center gap-4 mb-8">
                <a href="javascript:history.back()" class="text-gray-500 hover:text-primary transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                </a>
                <h1 class="text-2xl font-bold gradient-text">编辑资源</h1>
            </div>

            <form action="/resources/<%= resource.id %>/edit" method="POST" enctype="multipart/form-data" class="space-y-5">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">资源标题 <span class="text-red-500">*</span></label>
                    <input type="text" name="title" required maxlength="100" class="input-field" value="<%= resource.title %>" placeholder="请输入资源标题">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">大单元区域 <span class="text-red-500">*</span></label>
                    <select name="unitArea" required class="input-field">
                        <option value="">请选择区域</option>
                        <option value="幕府山" <%= resource.unit_area === '幕府山' ? 'selected' : '' %>>幕府山</option>
                        <option value="燕子矶" <%= resource.unit_area === '燕子矶' ? 'selected' : '' %>>燕子矶</option>
                        <option value="八卦洲" <%= resource.unit_area === '八卦洲' ? 'selected' : '' %>>八卦洲</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">大单元层次 <span class="text-red-500">*</span></label>
                    <select name="unitLevel" required class="input-field">
                        <option value="">请选择层次</option>
                        <option value="破坏与修复" <%= resource.unit_level === '破坏与修复' ? 'selected' : '' %>>破坏与修复（幕府山）</option>
                        <option value="干预与复苏" <%= resource.unit_level === '干预与复苏' ? 'selected' : '' %>>干预与复苏（燕子矶）</option>
                        <option value="转型与振兴" <%= resource.unit_level === '转型与振兴' ? 'selected' : '' %>>转型与振兴（八卦洲）</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">相关点位</label>
                    <input type="text" name="pointName" class="input-field" value="<%= resource.point_name || '' %>" placeholder="请输入相关点位名称（可选）">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">内容描述 <span class="text-gray-400 text-xs">（支持Markdown格式）</span></label>
                    <textarea id="contentEditor" name="content" rows="10" maxlength="5000" class="input-field resize-none" placeholder="请输入资源描述（支持Markdown格式）"><%= resource.content || '' %></textarea>
                </div>

                <!-- 已有图片 -->
                <% if (images && images.length > 0) { %>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">已有图片</label>
                    <div id="existingImages" class="grid grid-cols-5 gap-3">
                        <% images.forEach(function(img, i) { %>
                        <div class="relative aspect-square rounded-xl overflow-hidden glass existing-img" data-img="<%= img %>">
                            <img src="<%= img %>" class="w-full h-full object-cover">
                            <button type="button" onclick="removeExistingImage(this)" class="absolute top-1 right-1 w-6 h-6 bg-red-500 text-white rounded-full flex items-center justify-center hover:bg-red-600 transition">
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                            </button>
                        </div>
                        <% }); %>
                    </div>
                </div>
                <input type="hidden" name="existingImages" id="existingImagesInput" value="<%= JSON.stringify(images) %>">
                <% } %>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">上传新图片</label>
                    <div class="border-2 border-dashed border-primary/30 rounded-xl p-6 text-center hover:border-primary/60 transition cursor-pointer glass" onclick="document.getElementById('images').click()">
                        <svg class="w-12 h-12 mx-auto text-primary/40 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        <p class="text-gray-600 mb-1 font-medium">点击上传新图片</p>
                        <p class="text-sm text-gray-400">支持 JPG、PNG 格式，每张不超过5MB</p>
                    </div>
                    <input type="file" id="images" name="images" accept="image/*" multiple class="hidden" onchange="handleFileSelect(this)">
                    <div id="fileList" class="mt-4 grid grid-cols-5 gap-3"></div>
                </div>

                <% if (resource.is_public !== undefined) { %>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-3">可见性设置</label>
                    <div class="space-y-3">
                        <label class="flex items-center gap-3 p-4 glass rounded-xl cursor-pointer hover:bg-white/60 transition">
                            <input type="radio" name="isPublic" value="0" class="w-4 h-4 text-primary" <%= resource.is_public === 0 ? 'checked' : '' %>>
                            <div>
                                <p class="font-medium text-gray-800">私密</p>
                                <p class="text-sm text-gray-500">仅自己可见</p>
                            </div>
                        </label>
                        <label class="flex items-center gap-3 p-4 glass rounded-xl cursor-pointer hover:bg-white/60 transition">
                            <input type="radio" name="isPublic" value="1" class="w-4 h-4 text-primary" <%= resource.is_public === 1 ? 'checked' : '' %>>
                            <div>
                                <p class="font-medium text-gray-800">公开</p>
                                <p class="text-sm text-gray-500">所有用户可见</p>
                            </div>
                        </label>
                        <label class="flex items-center gap-3 p-4 glass rounded-xl cursor-pointer hover:bg-white/60 transition">
                            <input type="radio" name="isPublic" value="2" class="w-4 h-4 text-primary" <%= resource.is_public === 2 ? 'checked' : '' %>>
                            <div>
                                <p class="font-medium text-gray-800">教师资源</p>
                                <p class="text-sm text-gray-500">所有用户可见，带教师标识</p>
                            </div>
                        </label>
                    </div>
                </div>
                <% } %>

                <div class="flex gap-4 pt-4">
                    <a href="javascript:history.back()" class="flex-1 glass-strong px-6 py-3 rounded-xl text-gray-700 text-center hover:bg-white/60 transition font-medium">取消</a>
                    <button type="submit" class="flex-1 btn-primary text-white font-medium py-3 rounded-xl">保存修改</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/simplemde/latest/simplemde.min.js"></script>
<script>
const simplemde = new SimpleMDE({
    element: document.getElementById('contentEditor'),
    spellChecker: false,
    status: false,
    toolbar: [
        "bold", "italic", "heading", "|",
        "quote", "unordered-list", "ordered-list", "|",
        "link", "image", "preview", "|",
        "guide"
    ],
    placeholder: "请输入资源描述，支持Markdown格式...",
    previewRender: function(plainText) {
        return simplemde.markdown(plainText);
    }
});

function removeExistingImage(btn) {
    const container = document.getElementById('existingImages');
    const input = document.getElementById('existingImagesInput');
    const imgEl = btn.closest('.existing-img');
    const imgPath = imgEl.dataset.img;

    imgEl.remove();

    // 更新hidden input
    const remaining = Array.from(document.querySelectorAll('.existing-img')).map(el => el.dataset.img);
    input.value = JSON.stringify(remaining);
}

function handleFileSelect(input) {
    const fileList = document.getElementById('fileList');
    fileList.innerHTML = '';
    if (input.files.length > 10) { alert('最多只能上传10张图片'); input.value = ''; return; }
    for (let i = 0; i < input.files.length; i++) {
        const file = input.files[i];
        const reader = new FileReader();
        reader.onload = function(e) {
            const div = document.createElement('div');
            div.className = 'relative aspect-square rounded-xl overflow-hidden glass';
            div.innerHTML = '<img src="' + e.target.result + '" class="w-full h-full object-cover">';
            fileList.appendChild(div);
        };
        reader.readAsDataURL(file);
    }
}
</script>

<%- include('partials/footer') %>
