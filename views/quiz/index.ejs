<%- include('../partials/header') %>

<div class="container mx-auto px-4 py-8">
    <div class="text-center mb-8 animate-fadeInUp">
        <h1 class="text-3xl font-bold gradient-text mb-2">大单元闯关</h1>
        <p class="text-gray-600">围绕"破坏→修复→共生"知识链设计分层问题，检验学习成果</p>
    </div>

    <% if (!isAuthenticated) { %>
    <div class="max-w-2xl mx-auto">
        <div class="glass-strong rounded-3xl p-12 text-center">
            <div class="w-20 h-20 mx-auto mb-6 bg-primary/10 rounded-2xl flex items-center justify-center">
                <svg class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
            </div>
            <h2 class="text-2xl font-bold text-gray-800 mb-4">请先登录</h2>
            <p class="text-gray-600 mb-8">答题功能需要登录后才能使用</p>
            <div class="flex gap-4 justify-center">
                <a href="/login" class="btn-primary px-8 py-3 rounded-xl font-medium text-white">立即登录</a>
                <a href="/register" class="glass-strong px-8 py-3 rounded-xl font-medium text-primary hover:bg-primary hover:text-white transition">注册账号</a>
            </div>
        </div>
    </div>
    <% } else { %>

    <div class="max-w-6xl mx-auto">
        <!-- 年级选择器 -->
        <div class="flex justify-center gap-2 mb-6 animate-fadeInUp">
            <% gradeLevels.forEach(function(grade) { %>
            <a href="/quiz?grade=<%= encodeURIComponent(grade) %>"
                class="px-4 py-2 rounded-xl text-sm font-medium transition <%= currentGrade === grade ? 'btn-primary text-white shadow-lg' : 'glass-strong text-gray-600 hover:bg-white/40' %>">
                <%= grade %>
            </a>
            <% }); %>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
            <!-- 左侧栏 -->
            <div class="lg:col-span-1 space-y-6">
                <!-- 错题库 -->
                <div class="glass-strong rounded-2xl p-6 flex flex-col animate-fadeInUp animate-fadeInUp-delay-1">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-12 h-12 bg-gradient-to-br from-red-400 to-red-500 rounded-xl flex items-center justify-center shadow-lg">
                            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-bold text-gray-800">错题库</h3>
                            <p class="text-sm text-gray-500">针对性训练</p>
                        </div>
                    </div>
                    <div class="glass rounded-xl p-4 mb-4">
                        <div class="flex items-center justify-between">
                            <span class="text-sm text-gray-600">错题数量</span>
                            <span class="text-2xl font-bold text-red-500"><%= wrongCount %></span>
                        </div>
                    </div>
                    <a href="/quiz/wrong" class="w-full py-3 btn-accent text-white rounded-xl font-medium flex items-center justify-center gap-2">
                        <span>进入错题库</span>
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </a>
                </div>

                <!-- 定制化练习 -->
                <div class="glass-strong rounded-2xl p-6 flex flex-col animate-fadeInUp animate-fadeInUp-delay-2">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-12 h-12 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-xl flex items-center justify-center shadow-lg">
                            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-bold text-gray-800">定制化练习</h3>
                            <p class="text-sm text-gray-500">自由组卷</p>
                        </div>
                    </div>
                    <p class="text-xs text-gray-500 mb-4">根据学段、知识点、时长自由筛选，不计入考核成绩</p>
                    <a href="/quiz/custom" class="w-full py-3 bg-gradient-to-r from-indigo-500 to-purple-600 text-white rounded-xl font-medium flex items-center justify-center gap-2 hover:opacity-90 transition">
                        <span>进入练习</span>
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </a>
                </div>
            </div>

            <!-- 右侧模块卡片 -->
            <div class="lg:col-span-3">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
                    <div class="glass-strong rounded-2xl overflow-hidden card-hover group flex flex-col h-[477px] animate-fadeInUp animate-fadeInUp-delay-1">
                        <div class="h-32 bg-gradient-to-br from-red-500 to-orange-500 p-5 relative overflow-hidden flex-shrink-0">
                            <div class="absolute top-0 right-0 w-24 h-24 bg-white/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
                            <div class="relative">
                                <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center mb-3"><span class="text-xl font-bold text-white">01</span></div>
                                <h3 class="text-xl font-bold text-white">破坏与修复</h3>
                                <p class="text-sm text-white/80">幕府山区域</p>
                            </div>
                        </div>
                        <div class="p-5 flex-1 flex flex-col">
                            <div class="flex items-center justify-between mb-3">
                                <div class="flex gap-2">
                                    <span class="px-2 py-1 bg-blue-50 text-blue-600 text-xs rounded-full">选择</span>
                                    <span class="px-2 py-1 bg-orange-50 text-orange-600 text-xs rounded-full">判断</span>
                                </div>
                                <span class="text-gray-400 text-sm"><%= moduleStats['破坏与修复'].total %>题</span>
                            </div>
                            <p class="text-sm text-gray-500 mb-3 line-clamp-2">了解人类活动对自然的影响与修复技术</p>
                            <div class="flex items-center justify-between text-sm mb-auto">
                                <span class="text-gray-400">限时<%= moduleStats['破坏与修复'].time %>分钟 · 通关<%= moduleStats['破坏与修复'].passRate %>%</span>
                                <% if (moduleStats['破坏与修复'].accuracy > 0) { %><span class="text-primary font-medium"><%= moduleStats['破坏与修复'].accuracy %>%</span><% } %>
                            </div>
                            <button onclick="showStartModal('破坏与修复')" class="mt-4 w-full py-2.5 btn-accent text-white rounded-xl font-medium text-center group-hover:shadow-lg">开始闯关</button>
                        </div>
                    </div>

                    <div class="glass-strong rounded-2xl overflow-hidden card-hover group flex flex-col h-[477px] animate-fadeInUp animate-fadeInUp-delay-2">
                        <div class="h-32 bg-gradient-to-br from-blue-500 to-cyan-500 p-5 relative overflow-hidden flex-shrink-0">
                            <div class="absolute top-0 right-0 w-24 h-24 bg-white/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
                            <div class="relative">
                                <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center mb-3"><span class="text-xl font-bold text-white">02</span></div>
                                <h3 class="text-xl font-bold text-white">干预与复苏</h3>
                                <p class="text-sm text-white/80">燕子矶滨江</p>
                            </div>
                        </div>
                        <div class="p-5 flex-1 flex flex-col">
                            <div class="flex items-center justify-between mb-3">
                                <div class="flex gap-2">
                                    <span class="px-2 py-1 bg-blue-50 text-blue-600 text-xs rounded-full">选择</span>
                                    <span class="px-2 py-1 bg-orange-50 text-orange-600 text-xs rounded-full">判断</span>
                                </div>
                                <span class="text-gray-400 text-sm"><%= moduleStats['干预与复苏'].total %>题</span>
                            </div>
                            <p class="text-sm text-gray-500 mb-3 line-clamp-2">理解城市生态修复的干预策略与实践</p>
                            <div class="flex items-center justify-between text-sm mb-auto">
                                <span class="text-gray-400">限时<%= moduleStats['干预与复苏'].time %>分钟 · 通关<%= moduleStats['干预与复苏'].passRate %>%</span>
                                <% if (moduleStats['干预与复苏'].accuracy > 0) { %><span class="text-primary font-medium"><%= moduleStats['干预与复苏'].accuracy %>%</span><% } %>
                            </div>
                            <button onclick="showStartModal('干预与复苏')" class="mt-4 w-full py-2.5 btn-secondary text-white rounded-xl font-medium text-center group-hover:shadow-lg">开始闯关</button>
                        </div>
                    </div>

                    <div class="glass-strong rounded-2xl overflow-hidden card-hover group flex flex-col h-[477px] animate-fadeInUp animate-fadeInUp-delay-3">
                        <div class="h-32 bg-gradient-to-br from-green-500 to-teal-500 p-5 relative overflow-hidden flex-shrink-0">
                            <div class="absolute top-0 right-0 w-24 h-24 bg-white/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
                            <div class="relative">
                                <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center mb-3"><span class="text-xl font-bold text-white">03</span></div>
                                <h3 class="text-xl font-bold text-white">转型与振兴</h3>
                                <p class="text-sm text-white/80">八卦洲区域</p>
                            </div>
                        </div>
                        <div class="p-5 flex-1 flex flex-col">
                            <div class="flex items-center justify-between mb-3">
                                <div class="flex gap-2">
                                    <span class="px-2 py-1 bg-blue-50 text-blue-600 text-xs rounded-full">选择</span>
                                    <span class="px-2 py-1 bg-orange-50 text-orange-600 text-xs rounded-full">判断</span>
                                </div>
                                <span class="text-gray-400 text-sm"><%= moduleStats['转型与振兴'].total %>题</span>
                            </div>
                            <p class="text-sm text-gray-500 mb-3 line-clamp-2">探索可持续发展的振兴之路</p>
                            <div class="flex items-center justify-between text-sm mb-auto">
                                <span class="text-gray-400">限时<%= moduleStats['转型与振兴'].time %>分钟 · 通关<%= moduleStats['转型与振兴'].passRate %>%</span>
                                <% if (moduleStats['转型与振兴'].accuracy > 0) { %><span class="text-primary font-medium"><%= moduleStats['转型与振兴'].accuracy %>%</span><% } %>
                            </div>
                            <button onclick="showStartModal('转型与振兴')" class="mt-4 w-full py-2.5 bg-gradient-to-r from-green-500 to-teal-500 text-white rounded-xl font-medium text-center hover:opacity-90 transition group-hover:shadow-lg">开始闯关</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-3xl mx-auto mt-8">
        <div class="glass-strong rounded-2xl p-6 text-center">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <h3 class="font-bold text-gray-800 mb-4">答题说明</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm text-gray-600">
                <div><svg class="w-4 h-4 text-primary mx-auto mb-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg><span>提交即显示解析</span></div>
                <div><svg class="w-4 h-4 text-primary mx-auto mb-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg><span>错题自动入库</span></div>
                <div><svg class="w-4 h-4 text-primary mx-auto mb-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg><span>限时答题</span></div>
                <div><svg class="w-4 h-4 text-primary mx-auto mb-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg><span>支持提前交卷</span></div>
            </div>
        </div>
    </div>
    <% } %>
</div>

<div id="startModal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden" style="backdrop-filter:blur(4px);">
    <div class="glass-strong rounded-3xl max-w-lg w-full mx-4 overflow-hidden">
        <div id="modalHeader" class="h-24 p-6 flex items-center">
            <div class="w-16 h-16 bg-white/20 rounded-xl flex items-center justify-center">
                <span id="modalIcon" class="text-3xl font-bold text-white">01</span>
            </div>
            <div class="ml-4">
                <h3 id="modalTitle" class="text-xl font-bold text-white">破坏与修复</h3>
                <p class="text-white/80 text-sm">幕府山区域</p>
            </div>
        </div>
        <div class="p-6">
            <div class="bg-orange-50/80 border border-orange-200/50 rounded-xl p-4 mb-6">
                <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                    <div>
                        <p class="font-medium text-orange-800">考核说明</p>
                        <p class="text-sm text-orange-600">首次答题成绩将计入考核，后续再次闯关成绩无效，但可反复练习</p>
                    </div>
                </div>
            </div>
            <div class="mb-6">
                <h4 class="font-medium text-gray-700 mb-3 flex items-center gap-2">
                    <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    知识点
                </h4>
                <ul id="modalKnowledge" class="space-y-2">
                    <li class="text-sm text-gray-600 flex items-start gap-2"><span class="w-1.5 h-1.5 bg-primary rounded-full mt-2 flex-shrink-0"></span>幕府山采矿宕口的历史与现状</li>
                </ul>
            </div>
            <div class="mb-6">
                <h4 class="font-medium text-gray-700 mb-3 flex items-center gap-2">
                    <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    题型组成
                </h4>
                <div id="modalQuestionTypes" class="flex flex-wrap gap-2">
                    <span class="px-3 py-1 bg-blue-50 text-blue-600 rounded-full text-sm">选择题 3题</span>
                </div>
            </div>
            <div class="flex items-center justify-between glass rounded-xl p-4 mb-6">
                <div class="flex items-center gap-3">
                    <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span class="text-gray-600">答题时间</span>
                </div>
                <span id="modalTime" class="text-xl font-bold gradient-text">3分钟</span>
            </div>
            <button id="startQuizBtn" onclick="startQuiz()" class="w-full py-3 btn-primary text-white rounded-xl font-medium">进入闯关</button>
        </div>
    </div>
</div>

<script>
const moduleStats = <%- moduleStatsJson %>;

const moduleKnowledge = {
    '破坏与修复': ['幕府山采矿宕口的历史与现状', '生态修复的主要技术与措施', '植被恢复与生态重建', '人与自然和谐共生的理念'],
    '干预与复苏': ['滨江湿地生态系统修复', '工业遗址转型与城市更新', '工程治水向生态治水转变', '城市滨水空间的多功能利用'],
    '转型与振兴': ['八卦洲农业转型与生态农业', '乡村振兴战略与绿色发展', '生态保护与经济发展的共赢', '可持续发展理念与实践']
};

const moduleColors = {
    '破坏与修复': { bg: 'bg-gradient-to-r from-red-500 to-orange-500', number: '01' },
    '干预与复苏': { bg: 'bg-gradient-to-r from-blue-500 to-cyan-500', number: '02' },
    '转型与振兴': { bg: 'bg-gradient-to-r from-green-500 to-teal-500', number: '03' }
};

let currentLevel = '';

function showStartModal(level) {
    currentLevel = level;
    const header = document.getElementById('modalHeader');
    const icon = document.getElementById('modalIcon');
    const title = document.getElementById('modalTitle');
    const knowledgeList = document.getElementById('modalKnowledge');
    const questionTypes = document.getElementById('modalQuestionTypes');
    const modalTime = document.getElementById('modalTime');
    header.className = 'h-24 p-6 flex items-center ' + moduleColors[level].bg;
    icon.textContent = moduleColors[level].number;
    title.textContent = level;
    let knowledgeHtml = '';
    moduleKnowledge[level].forEach(item => {
        knowledgeHtml += '<li class="text-sm text-gray-600 flex items-start gap-2"><span class="w-1.5 h-1.5 bg-primary rounded-full mt-2 flex-shrink-0"></span>' + item + '</li>';
    });
    knowledgeList.innerHTML = knowledgeHtml;
    const stats = moduleStats[level];
    let typesHtml = '';
    if (stats.choice > 0) typesHtml += '<span class="px-3 py-1 bg-blue-50 text-blue-600 rounded-full text-sm">选择题 ' + stats.choice + '题</span>';
    if (stats.judge > 0) typesHtml += '<span class="px-3 py-1 bg-orange-50 text-orange-600 rounded-full text-sm">判断题 ' + stats.judge + '题</span>';
    if (stats.fill > 0) typesHtml += '<span class="px-3 py-1 bg-green-50 text-green-600 rounded-full text-sm">填空题 ' + stats.fill + '题</span>';
    if (stats.essay > 0) typesHtml += '<span class="px-3 py-1 bg-purple-50 text-purple-600 rounded-full text-sm">简答题 ' + stats.essay + '题</span>';
    questionTypes.innerHTML = typesHtml;
    modalTime.textContent = stats.time + '分钟';
    document.getElementById('startModal').classList.remove('hidden');
}

function startQuiz() {
    document.getElementById('startModal').classList.add('hidden');
    window.location.href = '/quiz/start?level=' + encodeURIComponent(currentLevel) + '&grade=' + encodeURIComponent('<%= currentGrade %>');
}

document.getElementById('startModal').addEventListener('click', function(e) {
    if (e.target === this) this.classList.add('hidden');
});
</script>

<%- include('../partials/footer') %>
