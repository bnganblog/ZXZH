<%- include('../partials/header') %>

<div class="container mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-8 animate-fadeInUp">
        <div class="flex items-center gap-4">
            <a href="/student" class="text-gray-500 hover:text-primary transition">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
            </a>
            <h1 class="text-2xl font-bold gradient-text">我的资源</h1>
        </div>
        <a href="/student/upload" class="btn-primary text-white px-5 py-2.5 rounded-xl text-sm font-medium transition">
            上传新资源
        </a>
    </div>

    <% if (resources.length > 0) { %>
    <div class="space-y-4">
        <% resources.forEach(function(r) { %>
        <div class="glass-strong rounded-2xl overflow-hidden card-hover">
            <div class="flex flex-col md:flex-row">
                <div class="w-full md:w-48 h-40 md:h-auto bg-gray-200 flex-shrink-0">
                    <% if (r.images && JSON.parse(r.images).length > 0) { %>
                        <img src="<%= JSON.parse(r.images)[0] %>" class="w-full h-full object-cover">
                    <% } else { %>
                        <div class="w-full h-full flex items-center justify-center text-gray-400 bg-gradient-to-br from-primary/10 to-primary/5">
                            <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                            </svg>
                        </div>
                    <% } %>
                </div>
                <div class="flex-grow p-6">
                    <div class="flex items-start justify-between mb-3">
                        <div>
                            <h3 class="text-lg font-bold text-gray-800 mb-1"><%= r.title %></h3>
                            <p class="text-sm text-gray-500"><%= r.unit_area %> · <%= r.unit_level %> · <%= r.created_at %></p>
                        </div>
                        <span class="px-3 py-1 text-xs rounded-full font-medium <%= r.is_public === 1 ? 'bg-blue-100 text-blue-700' : r.is_public === 2 ? 'bg-purple-100 text-purple-700' : 'bg-gray-200 text-gray-600' %>">
                            <%= r.is_public === 1 ? '公开' : r.is_public === 2 ? '教师发布' : '私密' %>
                        </span>
                    </div>
                    <p class="text-gray-600 text-sm line-clamp-2 mb-4"><%= r.content || '暂无描述' %></p>
                    <div class="flex items-center justify-between">
                        <div class="flex gap-2">
                            <a href="/resources/<%= r.id %>" class="text-primary hover:text-primary-light text-sm font-medium transition">查看</a>
                        </div>
                        <form action="/student/resources/delete/<%= r.id %>" method="POST" onsubmit="return confirm('确定要删除这个资源吗？')">
                            <button type="submit" class="text-red-500 hover:text-red-700 text-sm font-medium transition">删除</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <% }); %>
    </div>
    <% } else { %>
    <div class="glass-strong rounded-2xl p-12 text-center">
        <svg class="w-20 h-20 mx-auto mb-4 text-gray-300" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
        </svg>
        <p class="text-gray-500 mb-4">还没有上传任何资源</p>
        <a href="/student/upload" class="inline-block btn-primary text-white px-6 py-2.5 rounded-xl transition">上传第一个资源</a>
    </div>
    <% } %>
</div>

<%- include('../partials/footer') %>
