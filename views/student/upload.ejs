<%- include('../partials/header') %>

<div class="container mx-auto px-4 py-8">
    <div class="max-w-2xl mx-auto">
        <div class="glass-strong rounded-2xl p-8 animate-fadeInUp">
            <div class="flex items-center gap-4 mb-8">
                <a href="/student" class="text-gray-500 hover:text-primary transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                </a>
                <h1 class="text-2xl font-bold gradient-text">上传研学资源</h1>
            </div>

            <form action="/student/upload" method="POST" enctype="multipart/form-data" class="space-y-5">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">资源标题 <span class="text-red-500">*</span></label>
                    <input type="text" name="title" required maxlength="100" class="input-field" placeholder="请输入资源标题（不超过100字）">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">大单元区域 <span class="text-red-500">*</span></label>
                    <select name="unitArea" required class="input-field">
                        <option value="">请选择区域</option>
                        <option value="幕府山">幕府山</option>
                        <option value="燕子矶">燕子矶</option>
                        <option value="八卦洲">八卦洲</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">大单元层次 <span class="text-red-500">*</span></label>
                    <select name="unitLevel" required class="input-field">
                        <option value="">请选择层次</option>
                        <option value="破坏与修复">破坏与修复（幕府山）</option>
                        <option value="干预与复苏">干预与复苏（燕子矶）</option>
                        <option value="转型与振兴">转型与振兴（八卦洲）</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">相关点位</label>
                    <input type="text" name="pointName" class="input-field" placeholder="请输入相关点位名称（可选）">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">内容描述</label>
                    <textarea name="content" rows="5" maxlength="2000" class="input-field resize-none" placeholder="请输入资源描述（不超过2000字）"></textarea>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">上传图片</label>
                    <div class="border-2 border-dashed border-primary/30 rounded-xl p-6 text-center hover:border-primary/60 transition cursor-pointer glass" onclick="document.getElementById('images').click()">
                        <svg class="w-12 h-12 mx-auto text-primary/40 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        <p class="text-gray-600 mb-1 font-medium">点击上传图片</p>
                        <p class="text-sm text-gray-400">支持 JPG、PNG 格式，最多5张，每张不超过5MB</p>
                    </div>
                    <input type="file" id="images" name="images" accept="image/*" multiple class="hidden" onchange="handleFileSelect(this)">
                    <div id="fileList" class="mt-4 grid grid-cols-5 gap-3"></div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-3">可见性设置</label>
                    <div class="space-y-3">
                        <label class="flex items-center gap-3 p-4 glass rounded-xl cursor-pointer hover:bg-white/60 transition">
                            <input type="radio" name="isPublic" value="0" class="w-4 h-4 text-primary">
                            <div>
                                <p class="font-medium text-gray-800">私密</p>
                                <p class="text-sm text-gray-500">仅自己可见</p>
                            </div>
                        </label>
                        <label class="flex items-center gap-3 p-4 glass-strong rounded-xl cursor-pointer hover:bg-white/80 transition border-2 border-primary/20">
                            <input type="radio" name="isPublic" value="1" class="w-4 h-4 text-primary" checked>
                            <div>
                                <p class="font-medium text-gray-800">公开</p>
                                <p class="text-sm text-gray-500">所有用户可见</p>
                            </div>
                        </label>
                    </div>
                </div>
                <div class="flex gap-4 pt-4">
                    <a href="/student" class="flex-1 glass-strong px-6 py-3 rounded-xl text-gray-700 text-center hover:bg-white/60 transition font-medium">取消</a>
                    <button type="submit" class="flex-1 btn-primary text-white font-medium py-3 rounded-xl">上传资源</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function handleFileSelect(input) {
    const fileList = document.getElementById('fileList');
    fileList.innerHTML = '';
    if (input.files.length > 5) { alert('最多只能上传5张图片'); input.value = ''; return; }
    for (let i = 0; i < input.files.length; i++) {
        const file = input.files[i];
        if (file.size > 5 * 1024 * 1024) { alert('图片 ' + file.name + ' 超过5MB限制'); continue; }
        const reader = new FileReader();
        reader.onload = function(e) {
            const div = document.createElement('div');
            div.className = 'relative aspect-square rounded-xl overflow-hidden glass';
            div.innerHTML = '<img src="' + e.target.result + '" class="w-full h-full object-cover"><button type="button" onclick="removeFile(this, ' + i + ')" class="absolute top-1 right-1 w-6 h-6 bg-red-500 text-white rounded-full flex items-center justify-center hover:bg-red-600 transition"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>';
            fileList.appendChild(div);
        };
        reader.readAsDataURL(file);
    }
}
function removeFile(btn, index) { btn.parentElement.remove(); }
</script>

<%- include('../partials/footer') %>
