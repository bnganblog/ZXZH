<%- include('../partials/header') %>

<div class="container mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-8 animate-fadeInUp">
        <div class="flex items-center gap-4">
            <a href="/teacher" class="text-gray-500 hover:text-primary transition">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
            </a>
            <h1 class="text-2xl font-bold gradient-text">班级答题统计</h1>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="stat-card p-6">
            <p class="text-sm text-gray-600 mb-1">参与学生数</p>
            <p class="text-2xl font-bold gradient-text"><%= totalStudents || 0 %></p>
        </div>
        <div class="stat-card p-6">
            <p class="text-sm text-gray-600 mb-1">学生正确次数</p>
            <p class="text-2xl font-bold gradient-text"><%= quizStats.reduce((sum, q) => sum + q.correct, 0) %></p>
        </div>
        <div class="stat-card p-6">
            <p class="text-sm text-gray-600 mb-1">平均正确率</p>
            <p class="text-2xl font-bold gradient-text">
                <%= quizStats.length > 0 ?
                    (quizStats.reduce((sum, q) => sum + (q.accuracy || 0), 0) / quizStats.filter(q => q.attempts > 0).length || 0).toFixed(1) + '%' : '0%' %>
            </p>
        </div>
    </div>

    <div class="glass-strong rounded-2xl p-6 mb-8">
        <h2 class="text-xl font-bold text-gray-800 mb-6">各单元答题情况</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <% ['破坏与修复', '干预与复苏', '转型与振兴'].forEach(function(level) {
                const moduleData = moduleStats.find(m => m.unit_level === level);
                const studentCount = moduleData ? moduleData.studentCount : 0;
                const totalAttempts = moduleData ? moduleData.totalAttempts : 0;
                const totalCorrect = moduleData ? moduleData.totalCorrect : 0;
                const accuracy = totalAttempts > 0 ? (totalCorrect / totalAttempts * 100).toFixed(1) : 0;
            %>
            <div class="p-4 glass rounded-xl">
                <h3 class="font-medium text-gray-800 mb-2"><%= level %></h3>
                <div class="flex justify-between items-end">
                    <div>
                        <p class="text-2xl font-bold gradient-text"><%= studentCount %></p>
                        <p class="text-xs text-gray-500">作答人数</p>
                    </div>
                    <div class="text-right">
                        <p class="text-2xl font-bold <%= accuracy >= 70 ? 'text-green-600' : accuracy >= 50 ? 'text-yellow-600' : 'text-red-600' %>"><%= accuracy %>%</p>
                        <p class="text-xs text-gray-500">正确率</p>
                    </div>
                </div>
                <div class="mt-3 h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div class="h-full <%= accuracy >= 70 ? 'bg-green-500' : accuracy >= 50 ? 'bg-yellow-500' : 'bg-red-500' %> rounded-full" style="width: <%= accuracy %>%"></div>
                </div>
            </div>
            <% }); %>
        </div>
    </div>

    <div class="glass-strong rounded-2xl p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-6">题目详细统计</h2>

        <% if (quizStats.length > 0) { %>
        <% ['破坏与修复', '干预与复苏', '转型与振兴'].forEach(function(level) {
            const levelQuestions = quizStats.filter(q => q.unit_level === level);
            if (levelQuestions.length === 0) return;
        %>
        <div class="mb-8 last:mb-0">
            <h3 class="text-lg font-medium text-gray-800 mb-4 pb-2 border-b border-gray-200"><%= level %></h3>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200">
                            <th class="text-left py-3 px-4 font-medium text-gray-600">题目</th>
                            <th class="text-center py-3 px-4 font-medium text-gray-600">类型</th>
                            <th class="text-center py-3 px-4 font-medium text-gray-600">作答人数</th>
                            <th class="text-center py-3 px-4 font-medium text-gray-600">正确人数</th>
                            <th class="text-center py-3 px-4 font-medium text-gray-600">正确率</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% levelQuestions.forEach(function(q) { %>
                        <tr class="border-b border-gray-100 hover:bg-gray-50 transition">
                            <td class="py-3 px-4 text-gray-800"><%= q.question.length > 60 ? q.question.substring(0, 60) + '...' : q.question %></td>
                            <td class="text-center py-3 px-4">
                                <span class="px-2 py-0.5 rounded-full text-xs font-medium <%= q.question_type === 'choice' ? 'bg-blue-100 text-blue-700' : 'bg-orange-100 text-orange-700' %>">
                                    <%= q.question_type === 'choice' ? '选择' : '判断' %>
                                </span>
                            </td>
                            <td class="text-center py-3 px-4"><%= q.attempts %></td>
                            <td class="text-center py-3 px-4"><%= q.correct %></td>
                            <td class="text-center py-3 px-4">
                                <span class="<%= (q.accuracy || 0) >= 70 ? 'text-green-600' : (q.accuracy || 0) >= 50 ? 'text-yellow-600' : 'text-red-600' %> font-medium">
                                    <%= q.attempts > 0 ? q.accuracy + '%' : '-' %>
                                </span>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
        <% }); %>
        <% } else { %>
        <div class="text-center py-12 text-gray-500">
            <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
            <p>暂无答题数据</p>
        </div>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>
